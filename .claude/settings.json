{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(bench drop-site *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(DROP DATABASE *)",
      "Bash(bench --site * mysql)",
      "Read(sites/*/site_config.json)",
      "Read(sites/*/common_site_config.json)",
      "Read(sites/*/private/**)",
      "Read(config/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
